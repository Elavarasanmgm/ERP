# .gitignore - ERP System

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.production.local
.env.development.local
.env.test.local

# Build outputs
dist/
build/
.next/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# IDE and Editor
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# OS files
Thumbs.db
.DS_Store

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Testing
coverage/
.nyc_output/
.mocha_timeout

# Production build artifacts
.cache/
dist/
build/

# Temporary files
temp/
tmp/
*.tmp

# Database backup files
*.bak
*.trn
*.backup

# SSL certificates (for local dev - don't commit real certs!)
*.pem
ssl/

# Docker volumes
db-data/

# IDE specific files
.eslintcache
.stylelintcache
.prettierignore

# Package manager
pnpm-lock.yaml

# Misc
.env.example (don't ignore this - it's a template)
TODO.md
NOTES.md
.vercel
